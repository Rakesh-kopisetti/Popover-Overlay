      "backgroundColor": "#333333",
      "animationDuration": 200
    },
    {
      "id": "info-tooltip",
      "type": "tooltip",
      "position": "top",
      "content": "This is an informational tooltip that displays helpful hints to users.",
      "backgroundColor": "#2196F3",
      "animationDuration": 250
    },
    {
      "id": "main-dropdown",
      "type": "dropdown",
